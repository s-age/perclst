            "mcp__perclst__ts_get_references",
            "mcp__perclst__ts_analyze",
            "mcp__perclst__ts_checker"
          ]
        },
        {
          "type": "agent",
          "name": "review-feature-abort-validators-loop-reviewer",
          "task": "target_path: src/validators\nng_output_path: .claude/tmp/review-feature-abort-validators\n\nIf ng_output_path does not exist, there were no issues found in the initial review — exit immediately.",
          "procedure": "arch/review",
          "model": "sonnet",
          "allowed_tools": [
