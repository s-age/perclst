        "mcp__perclst__ts_checker"
      ]
    },
    {
      "type": "pipeline",
      "name": "review-feature-abort-validators-fix-loop",
      "tasks": [
        {
          "type": "agent",
          "name": "review-feature-abort-validators-implementer",
