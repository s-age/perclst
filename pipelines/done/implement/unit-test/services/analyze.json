{
  "tasks": [
    {
      "type": "script",
      "command": "npm run test:unit"
    },
    {
      "type": "pipeline",
      "name": "unit-test-analyze-service",
      "tasks": [
        {
          "type": "agent",
          "name": "implement-unit-test-analyze-service",
          "task": "target_file_path: src/services/analyzeService.ts",
          "procedure": "implement-unit-test",
