{
  "name": "cloader",
  "version": "0.1.0",
  "description": "CLI tool for managing Claude Code sub-agents",
  "type": "module",
  "bin": {
    "cloader": "./bin/cloader.js"
  },
  "files": [
    "dist/**/*",
    "bin/**/*",
    "procedures/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublish": "npm run build",
    "link": "npm link",
    "unlink": "npm unlink -g cloader"
  },
  "keywords": [
    "claude",
    "ai",
    "agent",
    "cli",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "ts-morph": "^27.0.2",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
