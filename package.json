{
  "name": "perclst",
  "version": "0.1.0",
  "description": "CLI tool for managing Claude Code sub-agents",
  "type": "module",
  "bin": {
    "perclst": "./bin/perclst.js"
  },
  "files": [
    "dist/**/*",
    "bin/**/*",
    "procedures/**/*"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepublish": "npm run build",
    "setup": "node scripts/setup.mjs",
    "link": "npm link && node scripts/setup.mjs",
    "unlink": "npm unlink -g perclst"
  },
  "keywords": [
    "claude",
    "ai",
    "agent",
    "cli",
    "typescript"
  ],
  "author": "",
  "license": "CC0-1.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "commander": "^12.0.0",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
